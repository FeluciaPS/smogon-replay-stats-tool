{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "bundler",
        "outDir": "./public/js",
        "rootDir": "./src",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
        "esModuleInterop": true
    },
    "include": ["src"]
}